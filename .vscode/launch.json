{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "RESOURCE_NAME": "IsaacSim"
            },
            "python": "~/isaacsim-4.2//kit/python/bin/python3",
            "envFile": "~/isaacsim-4.2//.vscode/.standalone_examples.env",
            "preLaunchTask": "setup_python_env"
        },
        {
            "name": "Python: Attach (windows-x86_64/linux-x86_64)",
            "type": "debugpy",
            "request": "attach"
        },
        {
            "name": "(Linux) isaac-sim",
            "type": "cppdbg",
            "request": "launch",
            "program": "~/isaacsim-4.2//kit/kit",
            "args": ["~/isaacsim-4.2//apps/omni.isaac.sim.kit",
                "--ext-folder", "~/isaacsim-4.2//exts",
                "--ext-folder", "~/isaacsim-4.2//apps"],
            "stopAtEntry": false,
            "cwd": "~/isaacsim-4.2/",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}